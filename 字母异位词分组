class Solution {
    public List<List<String>> groupAnagrams(String[] strs) {
        Map<String,List<String>> m=new HashMap<>();
        for(String s:strs){
            char[] sortS=s.toCharArray();
            Arrays.sort(sortS);
            m.computeIfAbsent(new String(sortS),_->new ArrayList<>()).add(s);
        } 
        return new ArrayList<>(m.values());
    }
}
